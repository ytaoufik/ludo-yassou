---
/**
 * LandingPage Component
 * Welcome screen with name input, create/join room functionality.
 */
---
<div id="landing-page" class="page active">
  <div class="landing-container">
    <!-- Animated background particles -->
    <div class="particles" aria-hidden="true">
      <span class="particle p1">🎲</span>
      <span class="particle p2">🎮</span>
      <span class="particle p3">⭐</span>
      <span class="particle p4">🎯</span>
      <span class="particle p5">🏆</span>
    </div>

    <!-- Title -->
    <div class="title-section">
      <h1 class="game-title">Bienvenue à <span class="highlight">LUDO</span> 🎮🎲</h1>
      <p class="subtitle">Le jeu de plateau classique — maintenant en ligne !</p>
    </div>

    <!-- Name Input -->
    <div class="input-section">
      <div class="input-group">
        <label for="player-name">Ton nom de joueur</label>
        <input
          type="text"
          id="player-name"
          placeholder="Entrez votre nom..."
          maxlength="20"
          autocomplete="off"
        />
      </div>
    </div>

    <!-- Action Buttons (hidden until name is entered) -->
    <div id="action-buttons" class="action-buttons hidden">
      <button id="btn-create-room" class="btn btn-primary">
        <span class="btn-icon">🏠</span>
        <span class="btn-text">Créer une Salle</span>
      </button>
      <div class="separator">
        <span>ou</span>
      </div>
      <button id="btn-join-room" class="btn btn-secondary">
        <span class="btn-icon">🔗</span>
        <span class="btn-text">Rejoindre une Salle</span>
      </button>
    </div>

    <!-- Join Room Code Input (hidden initially) -->
    <div id="join-section" class="join-section hidden">
      <div class="input-group">
        <label for="room-code">Code de la salle</label>
        <input
          type="text"
          id="room-code"
          placeholder="Ex: A1B2C3"
          maxlength="6"
          autocomplete="off"
          style="text-transform: uppercase;"
        />
      </div>
      <button id="btn-join-confirm" class="btn btn-accent">
        <span class="btn-text">Rejoindre</span>
        <span class="btn-icon">→</span>
      </button>
      <button id="btn-join-back" class="btn-link">← Retour</button>
    </div>

    <!-- Error message -->
    <div id="error-message" class="error-message hidden"></div>

    <!-- Footer -->
    <footer class="landing-footer">
      <p>Créé par yassou 😇</p>
    </footer>
  </div>
</div>

<style>
  .landing-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem 1.5rem;
    z-index: 1;
  }

  /* ─── Particles ─────────────────────────────────── */
  .particles {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    font-size: 1.5rem;
    opacity: 0.15;
    animation: float 6s ease-in-out infinite;
  }

  .p1 { top: 10%; left: 10%; animation-delay: 0s; }
  .p2 { top: 20%; right: 15%; animation-delay: 1s; }
  .p3 { bottom: 30%; left: 20%; animation-delay: 2s; }
  .p4 { top: 50%; right: 10%; animation-delay: 3s; }
  .p5 { bottom: 15%; right: 25%; animation-delay: 4s; }

  /* ─── Title ─────────────────────────────────────── */
  .title-section {
    text-align: center;
    margin-bottom: 2.5rem;
    animation: fadeIn 0.8s ease forwards;
  }

  .game-title {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.5px;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .highlight {
    background: linear-gradient(135deg, var(--accent-light), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    font-weight: 400;
  }

  /* ─── Input ─────────────────────────────────────── */
  .input-section {
    width: 100%;
    max-width: 380px;
    animation: slideUp 0.6s ease forwards;
    animation-delay: 0.2s;
    opacity: 0;
  }

  .input-group {
    margin-bottom: 1rem;
  }

  .input-group label {
    display: block;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .input-group input {
    width: 100%;
    padding: 0.9rem 1.2rem;
    background: var(--bg-card);
    border: 2px solid transparent;
    border-radius: 12px;
    color: var(--text-primary);
    font-size: 1rem;
    transition: var(--transition);
  }

  .input-group input:focus {
    border-color: var(--accent);
    background: var(--bg-card-hover);
    box-shadow: 0 0 0 4px rgba(108, 92, 231, 0.15);
  }

  .input-group input::placeholder {
    color: var(--text-secondary);
    opacity: 0.5;
  }

  /* ─── Buttons ───────────────────────────────────── */
  .action-buttons {
    width: 100%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 1rem 1.5rem;
    border-radius: 14px;
    font-size: 1rem;
    font-weight: 600;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }

  .btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .btn:hover::after {
    opacity: 1;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), #5a4bd1);
    color: white;
    box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(108, 92, 231, 0.4);
  }

  .btn-secondary {
    background: var(--bg-card);
    color: var(--text-primary);
    border: 2px solid rgba(108, 92, 231, 0.3);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
  }

  .btn-accent {
    background: linear-gradient(135deg, var(--green), #27ae60);
    color: white;
    box-shadow: 0 4px 15px rgba(46, 204, 113, 0.3);
    width: 100%;
    max-width: 380px;
  }

  .btn-accent:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(46, 204, 113, 0.4);
  }

  .btn-link {
    background: none;
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-top: 0.5rem;
    transition: color 0.2s;
  }

  .btn-link:hover {
    color: var(--accent-light);
  }

  .btn-icon {
    font-size: 1.2rem;
  }

  .separator {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .separator::before,
  .separator::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(160, 160, 192, 0.2);
  }

  /* ─── Join Section ──────────────────────────────── */
  .join-section {
    width: 100%;
    max-width: 380px;
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .join-section .input-group {
    width: 100%;
  }

  /* ─── Error Message ─────────────────────────────── */
  .error-message {
    margin-top: 1rem;
    padding: 0.8rem 1.2rem;
    background: rgba(231, 76, 60, 0.15);
    border: 1px solid rgba(231, 76, 60, 0.3);
    border-radius: 10px;
    color: var(--red-light);
    font-size: 0.9rem;
    max-width: 380px;
    width: 100%;
    text-align: center;
    animation: bounceIn 0.3s ease;
  }

  /* ─── Footer ────────────────────────────────────── */
  .landing-footer {
    margin-top: auto;
    padding-top: 3rem;
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
    opacity: 0.7;
  }

  /* ─── Utility ───────────────────────────────────── */
  .hidden {
    display: none !important;
  }

  .page {
    display: none;
  }

  .page.active {
    display: block;
  }

  /* ─── Mobile adjustments ────────────────────────── */
  @media (max-width: 480px) {
    .landing-container {
      padding: 1.5rem 1rem;
    }
    .game-title {
      font-size: 1.6rem;
    }
  }
</style>
