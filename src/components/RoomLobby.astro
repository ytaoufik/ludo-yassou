---
/**
 * RoomLobby Component
 * Shows the waiting room with room code, player list, countdown.
 */
---
<div id="lobby-page" class="page">
  <div class="lobby-container">
    <div class="lobby-card">
      <div class="lobby-header">
        <h2>🏠 Salle d'attente</h2>
        <div class="room-code-display">
          <span class="label">Code de la salle</span>
          <div class="code-box">
            <span id="display-room-code">------</span>
            <button id="btn-copy-code" class="copy-btn" title="Copier le code">📋</button>
          </div>
        </div>
      </div>

      <div class="players-section">
        <h3>Joueurs <span id="player-count">(0/4)</span></h3>
        <ul id="player-list" class="player-list">
          <!-- Players will be added dynamically -->
        </ul>
      </div>

      <div id="lobby-status" class="lobby-status">
        <div class="waiting-dots">
          <span>En attente d'autres joueurs</span>
          <div class="dots">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
        </div>
      </div>

      <div id="countdown-display" class="countdown hidden">
        <span>La partie commence dans</span>
        <div class="countdown-number" id="countdown-number">3</div>
      </div>
    </div>

    <div class="lobby-chat-container">
      <div class="chat-header">
        <h3>💬 Chat</h3>
      </div>
      <div id="lobby-chat-messages" class="chat-messages"></div>
      <div class="chat-input-row">
        <input
          type="text"
          id="lobby-chat-input"
          placeholder="Écrire un message..."
          maxlength="200"
          autocomplete="off"
        />
        <button id="lobby-chat-send" class="chat-send-btn">➤</button>
      </div>
    </div>
  </div>
</div>

<style>
  .lobby-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    min-height: 100vh;
    padding: 2rem 1.5rem;
    z-index: 1;
    position: relative;
  }

  .lobby-card {
    background: var(--bg-card);
    border-radius: var(--border-radius);
    padding: 2rem;
    width: 100%;
    max-width: 450px;
    box-shadow: var(--shadow);
    animation: fadeIn 0.5s ease;
  }

  .lobby-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .lobby-header h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .room-code-display {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .room-code-display .label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .code-box {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: var(--bg-dark);
    padding: 0.8rem 1.5rem;
    border-radius: 12px;
    border: 2px solid var(--accent);
  }

  .code-box span {
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: 6px;
    color: var(--accent-light);
    font-family: 'Courier New', monospace;
  }

  .copy-btn {
    background: none;
    font-size: 1.2rem;
    padding: 0.3rem;
    border-radius: 6px;
    transition: var(--transition);
  }

  .copy-btn:hover {
    background: rgba(108, 92, 231, 0.2);
  }

  /* ─── Player List ─────────────────────────────── */
  .players-section h3 {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 0.8rem;
  }

  .players-section h3 span {
    color: var(--accent-light);
  }

  .player-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .player-list :global(li) {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 1rem;
    background: var(--bg-dark);
    border-radius: 10px;
    animation: slideUp 0.3s ease;
  }

  .player-list :global(.player-color-dot) {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .player-list :global(.player-name-text) {
    font-weight: 500;
    flex: 1;
  }

  .player-list :global(.you-badge) {
    font-size: 0.7rem;
    background: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 6px;
    font-weight: 600;
  }

  /* ─── Status ──────────────────────────────────── */
  .lobby-status {
    text-align: center;
    margin-top: 1.5rem;
    color: var(--text-secondary);
  }

  .waiting-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .dots {
    display: flex;
    gap: 3px;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 1.4s ease-in-out infinite;
  }

  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }

  /* ─── Countdown ───────────────────────────────── */
  .countdown {
    text-align: center;
    margin-top: 1.5rem;
    color: var(--text-secondary);
  }

  .countdown-number {
    font-size: 3rem;
    font-weight: 800;
    color: var(--accent-light);
    animation: pulse 1s ease-in-out infinite;
  }

  /* ─── Chat ────────────────────────────────────── */
  .lobby-chat-container {
    background: var(--bg-card);
    border-radius: var(--border-radius);
    width: 100%;
    max-width: 450px;
    box-shadow: var(--shadow);
    overflow: hidden;
    animation: fadeIn 0.5s ease 0.2s both;
  }

  .chat-header {
    padding: 1rem 1.2rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .chat-header h3 {
    font-size: 0.95rem;
  }

  .chat-messages {
    height: 180px;
    overflow-y: auto;
    padding: 0.8rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .chat-input-row {
    display: flex;
    gap: 0.5rem;
    padding: 0.8rem 1rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .chat-input-row input {
    flex: 1;
    padding: 0.6rem 1rem;
    background: var(--bg-dark);
    border-radius: 10px;
    color: var(--text-primary);
    font-size: 0.9rem;
  }

  .chat-send-btn {
    background: var(--accent);
    color: white;
    border-radius: 10px;
    padding: 0.6rem 1rem;
    font-size: 1rem;
    transition: var(--transition);
  }

  .chat-send-btn:hover {
    background: var(--accent-light);
  }

  .hidden {
    display: none !important;
  }

  .page {
    display: none;
  }

  .page.active {
    display: block;
  }
</style>
